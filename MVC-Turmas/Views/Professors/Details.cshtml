@model MVC_Turmas.Data.Turma.Professor

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Professor</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Nome)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Nome)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.DataNascimento)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.DataNascimento)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.AreaEnsino)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.AreaEnsino)
        </dd>
        <dt class="col-sm-2">Turmas que Dirige</dt>
        <dd class="col-sm-10">
            @if (Model.TurmasADirigir != null && Model.TurmasADirigir.Any())
            {
                <ul>
                    @foreach (var turma in Model.TurmasADirigir)
                    {
                        <li>@turma.Descricao</li>
                    }
                </ul>
            }
            else
            {
                <span>Nenhuma turma atribuída</span>
            }
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>
